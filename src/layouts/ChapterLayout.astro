---
import BaseLayout from './BaseLayout.astro';

interface Props {
  chapterNumber: number;
  chapterName: string;
  sanskritName: string;
  summary: string;
  illustration?: string;
}

const { chapterNumber, chapterName, sanskritName, summary, illustration } = Astro.props;
---

<BaseLayout title={`Chapter ${chapterNumber}: ${chapterName} — Gita Kids`}>
  <!-- Optional hero illustration -->
  {illustration && (
    <div class="max-w-4xl mx-auto -mt-2">
      <img
        src={illustration}
        alt={`Illustration for Chapter ${chapterNumber}`}
        class="w-full"
        loading="eager"
      />
    </div>
  )}

  <div class="max-w-reading mx-auto px-4 py-12">
    <!-- Chapter Header -->
    <header class="text-center mb-12">
      <span class="font-ui text-xs font-semibold uppercase tracking-widest text-gold">
        Chapter {chapterNumber}
      </span>
      <h1 class="font-body text-3xl md:text-4xl font-bold text-gray-900 mt-3 mb-2">
        {chapterName}
      </h1>
      <p lang="sa" class="font-devanagari text-xl text-saffron/70">
        {sanskritName}
      </p>
      <p class="font-body text-base text-gray-600 mt-4 max-w-lg mx-auto leading-relaxed">
        {summary}
      </p>
    </header>

    <slot />
  </div>
</BaseLayout>
