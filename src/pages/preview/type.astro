---
// Typography specimen — PREVIEW ONLY. Not linked anywhere; reachable at /preview/type.
// Compares a few type systems on the same real verse (BG 2.47) so the owner can choose.
import { getVerse } from '../../lib/content';

const v = getVerse('02-sankhya-yoga', '047')!;

const systems = [
  {
    id: 'current',
    label: 'Current — live today',
    note: 'Noto Serif Devanagari + Source Serif 4 + Inter. The transliteration sits in a different family from the Devanagari.',
    disp: '"Source Serif 4", Georgia, serif',
    deva: '"Noto Serif Devanagari", serif',
    translit: '"Source Serif 4", Georgia, serif',
    body: '"Source Serif 4", Georgia, serif',
    recommended: false,
  },
  {
    id: 'classical',
    label: 'Classical — recommended',
    note: 'Tiro Devanagari Sanskrit (the Murty Classical Library face — Devanagari and IAST in one family) + Fraunces display + Source Serif 4 body.',
    disp: '"Fraunces", Georgia, serif',
    deva: '"Tiro Devanagari Sanskrit", serif',
    translit: '"Tiro Devanagari Sanskrit", serif',
    body: '"Source Serif 4", Georgia, serif',
    recommended: true,
  },
  {
    id: 'editorial',
    label: 'Editorial',
    note: 'Tiro Devanagari Sanskrit + Playfair Display (high-contrast display) + Spectral body. More magazine-like.',
    disp: '"Playfair Display", Georgia, serif',
    deva: '"Tiro Devanagari Sanskrit", serif',
    translit: '"Tiro Devanagari Sanskrit", serif',
    body: '"Spectral", Georgia, serif',
    recommended: false,
  },
  {
    id: 'warm',
    label: 'Warm',
    note: 'Tiro Devanagari Sanskrit + Marcellus (calm Roman caps) display + Source Serif 4 body + Baloo 2 labels. Gentlest, most kid-warm.',
    disp: '"Marcellus", Georgia, serif',
    deva: '"Tiro Devanagari Sanskrit", serif',
    translit: '"Tiro Devanagari Sanskrit", serif',
    body: '"Source Serif 4", Georgia, serif',
    recommended: false,
  },
];

const meaning = 'You have a right to action alone, never to its fruits. Do not let the fruit of action be your motive. Nor let there be attachment to inaction.';
const chips = v.dhatu_breakdown.slice(0, 4);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Type options — Gita Kids preview</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Sanskrit:ital@0;1&family=Noto+Serif+Devanagari:wght@400;600;700&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Spectral:ital,wght@0,400;0,600;1,400&family=Marcellus&family=Source+Serif+4:ital,wght@0,400;0,600;0,700;1,400&family=Baloo+2:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --cream: #FDF6E3;
        --ink: #2a2520;
        --ink-soft: #5b5346;
        --saffron: #C75B12;
        --indigo: #2D3A87;
        --gold: #C4A24E;
        --line: rgba(196, 162, 78, 0.30);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body {
        background: var(--cream);
        color: var(--ink);
        font-family: "Inter", system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wrap { max-width: 860px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
      .page-head { text-align: center; margin-bottom: 3.5rem; }
      .kicker {
        font-family: "Inter", sans-serif; font-size: 0.72rem; font-weight: 600;
        letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold);
      }
      .page-head h1 {
        font-family: "Fraunces", serif; font-weight: 500; font-size: clamp(2rem, 5vw, 3rem);
        margin: 0.6rem 0 0.4rem; color: var(--ink); line-height: 1.05;
      }
      .page-head p { color: var(--ink-soft); font-size: 1rem; max-width: 48ch; margin: 0.4rem auto 0; line-height: 1.6; }

      .sys { margin: 0 0 2.25rem; background: #fffdf7; border: 1px solid rgba(0,0,0,0.06);
             border-radius: 18px; overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.03); }
      .sys-head { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap;
                  padding: 1rem 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.06);
                  background: linear-gradient(to right, rgba(196,162,78,0.06), transparent); }
      .sys-head .name { font-family: "Inter", sans-serif; font-size: 0.78rem; font-weight: 700;
                        letter-spacing: 0.16em; text-transform: uppercase; color: var(--saffron); }
      .sys-head .name.rec { color: var(--indigo); }
      .badge { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
               color: #fff; background: var(--indigo); padding: 0.18rem 0.5rem; border-radius: 999px; }
      .sys-head .note { font-family: "Inter", sans-serif; font-size: 0.8rem; color: var(--ink-soft);
                        flex: 1 1 280px; line-height: 1.5; }

      .specimen { padding: 2rem 2rem 2.25rem; }
      .liner { font-family: "Inter", sans-serif; font-size: 0.7rem; font-weight: 600;
               letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
      .display { font-family: var(--disp); font-weight: 500; font-size: clamp(1.7rem, 4vw, 2.4rem);
                 line-height: 1.1; margin: 0 0 1.4rem; color: var(--ink); }
      .sanskrit { font-family: var(--deva); font-size: clamp(1.5rem, 4vw, 2.05rem); line-height: 1.7;
                  color: var(--indigo); margin: 0 0 0.6rem; }
      .translit { font-family: var(--translit); font-style: italic; font-size: 1.05rem;
                  color: var(--ink-soft); margin: 0 0 1.5rem; line-height: 1.6; }
      .meaning { font-family: var(--body); font-size: 1.18rem; line-height: 1.72; color: var(--ink);
                 max-width: 60ch; margin: 0; }
      .meaning::first-letter { font-family: var(--disp); font-weight: 600; font-size: 3.1em;
                 line-height: 0.78; float: left; padding: 0.05em 0.09em 0 0; color: var(--saffron); }
      .chips { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.6rem; }
      .chip { display: inline-flex; align-items: baseline; gap: 0.4rem; border: 1px solid var(--line);
              background: rgba(196,162,78,0.05); border-radius: 10px; padding: 0.35rem 0.7rem; }
      .chip .w { font-family: var(--deva); font-size: 1.05rem; color: var(--saffron); }
      .chip .m { font-family: "Inter", sans-serif; font-size: 0.74rem; color: var(--ink-soft); }

      .foot { text-align: center; margin-top: 3rem; color: var(--ink-soft); font-size: 0.85rem; }
      .foot a { color: var(--saffron); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="page-head">
        <div class="kicker">Gita Kids · Typography preview</div>
        <h1>Four ways to set the verse</h1>
        <p>The same shloka (Bhagavad Gita 2.47) in four type systems. Same words, same colours — only the fonts change. Pick the one that feels right.</p>
      </header>

      {systems.map((s) => (
        <article class="sys" style={`--disp:${s.disp}; --deva:${s.deva}; --translit:${s.translit}; --body:${s.body}`}>
          <div class="sys-head">
            <span class={`name ${s.recommended ? 'rec' : ''}`}>{s.label}</span>
            {s.recommended && <span class="badge">Recommended</span>}
            <span class="note">{s.note}</span>
          </div>
          <div class="specimen">
            <div class="liner">Chapter 2 · Verse 47</div>
            <h2 class="display">{v.story.title}</h2>
            <p class="sanskrit">{v.sanskrit}</p>
            <p class="translit">{v.transliteration}</p>
            <p class="meaning">{meaning}</p>
            <div class="chips">
              {chips.map((c) => (
                <span class="chip"><span class="w">{c.word}</span><span class="m">{c.meaning}</span></span>
              ))}
            </div>
          </div>
        </article>
      ))}

      <p class="foot">Preview only. See the sample home layout at <a href="/preview/home">/preview/home</a>.</p>
    </div>
  </body>
</html>
