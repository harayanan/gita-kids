---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllChapters } from '../lib/content';

const chapters = getAllChapters();

// Color accents based on folk_art_style
const styleColors: Record<string, string> = {
  madhubani:   '#C75B12',
  gond:        '#2D3A87',
  pichwai:     '#2D3A87',
  pattachitra: '#B85C3A',
  warli:       '#B85C3A',
  kalamkari:   '#1A6847',
};
---

<BaseLayout>
  <!-- Hero Section with illustration background -->
  <section class="relative overflow-hidden">
    <!-- Background illustration -->
    <div class="absolute inset-0">
      <img
        src="/illustrations/01-arjuna-vishada-yoga/001.png"
        alt=""
        class="w-full h-full object-cover object-top"
        aria-hidden="true"
      />
      <!-- Cream gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-cream/80 via-cream/70 to-cream"></div>
    </div>

    <div class="relative max-w-reading mx-auto text-center px-4 pt-24 pb-20">
      <p lang="sa" class="font-devanagari text-5xl md:text-6xl text-saffron mb-5 drop-shadow-sm">
        श्रीमद्भगवद्गीता
      </p>
      <h1 class="font-body text-2xl md:text-3xl font-bold text-gray-900 mb-3">
        The Bhagavad Gita
      </h1>
      <p class="font-body text-lg text-gray-600 mb-2">
        For Young Explorers
      </p>
      <p class="font-body text-base text-gray-600 max-w-md mx-auto mt-6 leading-relaxed">
        An illustrated journey through ancient India's most beloved scripture.
        Word by word, story by story — for curious minds aged 8 to 12.
      </p>

      <!-- Om divider -->
      <div class="flex items-center justify-center gap-4 mt-10">
        <div class="w-16 h-px bg-gold/40"></div>
        <span lang="sa" class="om-symbol font-devanagari text-gold text-5xl leading-none select-none" aria-label="Om">ॐ</span>
        <div class="w-16 h-px bg-gold/40"></div>
      </div>
    </div>
  </section>

  <!-- Dhyanashloka CTA -->
  <section class="px-4 pb-4">
    <div class="max-w-reading mx-auto">
      <a href="/dhyanashloka" class="block rounded-xl border border-gold/30 bg-white/50 hover:border-saffron hover:shadow-lg transition-all p-6 text-center group">
        <span lang="sa" class="font-devanagari text-2xl text-saffron/70 group-hover:text-saffron transition-colors">ध्यानश्लोक</span>
        <p class="font-body text-sm text-gray-600 mt-2">
          Begin with the nine meditation verses — the traditional opening before studying the Gita.
        </p>
        <span class="inline-block mt-3 font-ui text-xs font-semibold text-saffron uppercase tracking-widest">
          Read Dhyanashloka &rarr;
        </span>
      </a>
    </div>
  </section>

  <!-- Front Matter Links -->
  <section class="px-4 pb-4">
    <div class="max-w-reading mx-auto flex gap-4">
      <a href="/characters" class="flex-1 block rounded-xl border border-gold/20 bg-white/40 hover:border-saffron hover:shadow-sm transition-all p-5 text-center group">
        <span class="font-body text-base font-semibold text-gray-800 group-hover:text-saffron transition-colors">Characters</span>
        <p class="font-body text-sm text-gray-600 mt-1">Meet the people of the Gita</p>
      </a>
      <a href="/pronunciation" class="flex-1 block rounded-xl border border-gold/20 bg-white/40 hover:border-saffron hover:shadow-sm transition-all p-5 text-center group">
        <span class="font-body text-base font-semibold text-gray-800 group-hover:text-saffron transition-colors">Pronunciation</span>
        <p class="font-body text-sm text-gray-600 mt-1">How to say Sanskrit words</p>
      </a>
    </div>
  </section>

  <!-- Chapter Grid -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-ui text-xs font-semibold uppercase tracking-widest text-gold text-center mb-10">
        18 Chapters
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {chapters.map((chapter, index) => {
          const isActive = chapter.status === 'active';
          const isFirst = index === 0;
          const borderColor = styleColors[chapter.folk_art_style] || '#C4A24E';
          return (
            <a
              href={isActive ? `/chapters/${chapter.slug}` : undefined}
              class:list={[
                'chapter-card block rounded-xl border p-6 transition-all scroll-reveal',
                isActive
                  ? 'border-gold/30 hover:border-saffron hover:shadow-lg cursor-pointer bg-white/50'
                  : 'border-gray-200 cursor-default bg-gray-50/50 grayscale opacity-40',
                isFirst && 'sm:col-span-2 lg:col-span-1 ring-1 ring-saffron/20 shadow-md',
              ]}
              style={`border-left: 4px solid ${isActive ? borderColor : '#d1d5db'}; transition-delay: ${index * 0.06}s`}
            >
              <div class="flex items-start justify-between mb-3">
                <span class="font-ui text-xs font-bold text-gold">
                  {String(chapter.number).padStart(2, '0')}
                </span>
                {!isActive && (
                  <span class="font-ui text-[10px] uppercase tracking-widest text-gray-500">
                    Coming soon
                  </span>
                )}
                {isFirst && isActive && (
                  <span class="font-ui text-[10px] uppercase tracking-widest text-saffron bg-saffron/10 px-2 py-0.5 rounded-full">
                    Start here
                  </span>
                )}
              </div>
              <h3 class="font-body text-lg font-semibold text-gray-900 mb-1">
                {chapter.name}
              </h3>
              <p lang="sa" class="font-devanagari text-sm text-saffron/60 mb-3">
                {chapter.sanskrit_name}
              </p>
              <p class="font-body text-sm text-gray-600 leading-relaxed line-clamp-3">
                {chapter.summary}
              </p>
              <div class="mt-4 font-ui text-xs text-gray-500">
                {chapter.verse_count} verses
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- What is the Gita? -->
  <section class="py-16 px-4">
    <div class="max-w-reading mx-auto">
      <!-- Sanskrit-style divider top -->
      <div class="flex items-center gap-3 mb-8">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
        <span lang="sa" class="font-devanagari text-gold/50 text-sm">परिचय</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      </div>

      <div class="text-center scroll-reveal">
        <h2 class="font-body text-2xl md:text-3xl font-bold text-gray-900 mb-6">What is the Gita?</h2>
        <p class="font-body text-lg text-gray-700 leading-relaxed mb-5">
          Over 5,000 years ago, on a battlefield called Kurukshetra, a warrior named
          Arjuna faced the hardest moment of his life. His charioteer, Krishna — who
          was actually God in human form — spoke 700 verses of wisdom that changed
          everything.
        </p>
        <p class="font-body text-lg text-gray-700 leading-relaxed">
          Those verses became the Bhagavad Gita — "The Song of God." It teaches us
          about courage, duty, love, and finding out who we really are. This site
          brings those teachings to life, one verse at a time, with stories you'll
          remember and words you'll understand.
        </p>
      </div>

      <!-- Sanskrit-style divider bottom -->
      <div class="flex items-center gap-3 mt-8">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
        <span lang="sa" class="font-devanagari text-gold/50 text-sm" aria-hidden="true">॥</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Om glyph appear animation */
  .om-symbol {
    display: inline-block;
    animation: om-appear 0.9s ease-out 0.4s both;
  }

  @keyframes om-appear {
    from {
      opacity: 0;
      transform: scale(0.6);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .om-symbol {
      animation: none;
    }
  }
</style>
