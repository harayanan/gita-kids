---
import ChapterLayout from '../../../layouts/ChapterLayout.astro';
import ChapterNav from '../../../components/ChapterNav.astro';
import { getAllChapters, getChapter, getChapterVerses, getArtStyle } from '../../../lib/content';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const chapters = getAllChapters();
  return chapters
    .filter((c) => c.status === 'active')
    .map((c) => ({
      params: { chapter: c.slug },
    }));
}

const { chapter: slug } = Astro.params;
const chapter = getChapter(slug!);
if (!chapter) return Astro.redirect('/');

const verses = getChapterVerses(slug!);
const allChapters = getAllChapters();

// Find the first verse illustration for the hero
const firstIllustration = fs.existsSync(path.resolve(`public/illustrations/${slug}/001.png`))
  ? `/illustrations/${slug}/001.png` : undefined;

// Color accents based on folk_art_style
const styleColors: Record<string, string> = {
  madhubani:   '#C75B12',
  gond:        '#2D3A87',
  pichwai:     '#2D3A87',
  pattachitra: '#B85C3A',
  warli:       '#B85C3A',
  kalamkari:   '#1A6847',
};

const accentColor = styleColors[chapter.folk_art_style] || '#C4A24E';

const artStyle = getArtStyle(chapter.folk_art_style);

// Speaker label formatting
function formatSpeaker(speaker: string): string {
  return speaker.charAt(0).toUpperCase() + speaker.slice(1);
}
---

<ChapterLayout
  chapterNumber={chapter.number}
  chapterName={chapter.name}
  sanskritName={chapter.sanskrit_name}
  summary={chapter.summary}
  illustration={firstIllustration}
>
  <!-- Summary / quick-reference link -->
  <a
    href={`/chapters/${slug}/summary`}
    class="mb-6 flex items-center gap-3 rounded-xl border border-gold/25 bg-cream/60 px-5 py-3.5 transition-all hover:border-saffron/40 hover:shadow-sm scroll-reveal"
    style={`border-left: 4px solid ${accentColor}`}
  >
    <span class="font-devanagari text-lg" style={`color: ${accentColor}`}>&#x2630;</span>
    <span class="flex-1">
      <span class="block font-body text-sm font-semibold text-gray-800">Verse summary</span>
      <span class="block font-ui text-xs text-gray-500">All {verses.length} verses — Sanskrit and English, side by side</span>
    </span>
    <span class="font-ui text-sm text-saffron shrink-0">View &rarr;</span>
  </a>

  <!-- Art style callout -->
  {artStyle && (
    <details class="mb-10 rounded-xl border border-gold/20 bg-cream/60 scroll-reveal group" style={`border-left: 4px solid ${accentColor}`}>
      <summary class="cursor-pointer px-6 py-4 flex items-center gap-3 select-none">
        <span class="font-devanagari text-lg" style={`color: ${accentColor}`}>&#x2736;</span>
        <span class="font-body text-sm font-semibold text-gray-700">
          Art Style: {artStyle.name} from {artStyle.region}
        </span>
        <span class="ml-auto font-ui text-xs text-gray-500 group-open:hidden">Learn more</span>
        <span class="ml-auto font-ui text-xs text-gray-500 hidden group-open:inline">Close</span>
      </summary>
      <div class="px-6 pb-5 pt-1 space-y-3">
        <p class="font-body text-sm text-gray-600 leading-relaxed">{artStyle.description}</p>
        <div>
          <p class="font-ui text-xs font-semibold uppercase tracking-wider text-gray-600 mb-1.5">Signature Elements</p>
          <ul class="space-y-1">
            {artStyle.signature_elements.map((el: string) => (
              <li class="font-body text-sm text-gray-600 flex items-start gap-2">
                <span class="text-gold mt-0.5 shrink-0">&#x2022;</span>
                <span>{el}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-lg bg-saffron/5 border border-saffron/10 px-4 py-3">
          <p class="font-ui text-xs font-semibold text-saffron mb-1">Did you know?</p>
          <p class="font-body text-sm text-gray-600 leading-relaxed">{artStyle.fun_fact}</p>
        </div>
      </div>
    </details>
  )}

  <!-- Verse list -->
  {verses.length > 0 ? (
    <div class="space-y-3">
      {verses.map((v, index) => (
        <a
          href={`/chapters/${slug}/${String(v.verse).padStart(3, '0')}`}
          class="block rounded-lg border border-gold/15 hover:border-saffron/40 p-5 transition-all hover:shadow-sm bg-white/40 scroll-reveal"
          style={`border-left: 3px solid ${accentColor}; transition-delay: ${Math.min(index * 0.05, 1)}s`}
        >
          <div class="flex items-start gap-4">
            <span class="font-ui text-xs font-bold text-gold shrink-0 mt-1">
              {chapter.number}.{v.verse}
            </span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <p lang="sa" class="font-devanagari text-base text-gray-800 truncate">{v.sanskrit}</p>
                <span class="font-ui text-[10px] uppercase tracking-wider text-gray-500 bg-gray-100 px-1.5 py-0.5 rounded shrink-0">
                  {formatSpeaker(v.speaker)}
                </span>
              </div>
              <p class="font-body text-sm text-gray-600 mt-1 truncate">{v.meaning}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="text-center py-16">
      <p lang="sa" class="font-devanagari text-2xl text-saffron/40 mb-4" aria-hidden="true">॥</p>
      <p class="font-body text-gray-600">Content for this chapter is being written.</p>
      <p class="font-ui text-sm text-gray-500 mt-2">Check back soon!</p>
    </div>
  )}

  <ChapterNav chapters={allChapters} currentChapter={chapter.number} />
</ChapterLayout>
