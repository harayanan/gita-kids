---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShlokaCard from '../../../components/ShlokaCard.astro';
import VerseNav from '../../../components/VerseNav.astro';
import { getAllChapters, getChapter, getChapterVerses, getVerse, getGlossary, getIllustrationAltText } from '../../../lib/content';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const chapters = getAllChapters().filter((c) => c.status === 'active');
  const paths: { params: { chapter: string; verse: string } }[] = [];

  for (const ch of chapters) {
    const verses = getChapterVerses(ch.slug);
    for (const v of verses) {
      paths.push({
        params: {
          chapter: ch.slug,
          verse: String(v.verse).padStart(3, '0'),
        },
      });
    }
  }

  return paths;
}

const { chapter: slug, verse: verseNum } = Astro.params;
const chapter = getChapter(slug!);
const verse = getVerse(slug!, verseNum!);
if (!chapter || !verse) return Astro.redirect('/');

const glossary = getGlossary();

// Check if illustration exists in public/
const illustrationFile = path.resolve(`public/illustrations/${slug}/${verseNum}.png`);
const illustrationPath = fs.existsSync(illustrationFile) ? `/illustrations/${slug}/${verseNum}.png` : undefined;
const illustrationAlt = illustrationPath ? getIllustrationAltText(slug!, verseNum!) : undefined;

// Compute next active chapter for end-of-chapter CTA
const allChapters = getAllChapters();
const activeChapters = allChapters
  .filter((c) => c.status === 'active')
  .sort((a, b) => a.number - b.number);
const currentIdx = activeChapters.findIndex((c) => c.number === chapter.number);
const nextChapter = currentIdx >= 0 && currentIdx < activeChapters.length - 1
  ? { slug: activeChapters[currentIdx + 1].slug, number: activeChapters[currentIdx + 1].number, name: activeChapters[currentIdx + 1].name }
  : null;
---

<BaseLayout title={`${chapter.name} ${chapter.number}.${verse.verse} — Gita Kids`}>
  <nav slot="breadcrumb" class="max-w-reading mx-auto px-6 pt-5 pb-2">
    <ol class="flex items-center gap-2 font-ui text-xs text-gray-500">
      <li><a href="/" class="hover:text-saffron transition-colors">Home</a></li>
      <li class="text-gold/40">&rsaquo;</li>
      <li><a href={`/chapters/${slug}`} class="hover:text-saffron transition-colors">Chapter {chapter.number}</a></li>
      <li class="text-gold/40">&rsaquo;</li>
      <li class="text-gray-600">Verse {verse.verse}</li>
    </ol>
  </nav>

  <VerseNav
    chapterSlug={slug!}
    currentVerse={verse.verse}
    totalVerses={chapter.verse_count}
    position="top"
    nextChapter={nextChapter}
  />

  <ShlokaCard
    chapter={verse.chapter}
    verse={verse.verse}
    speaker={verse.speaker}
    sanskrit={verse.sanskrit}
    transliteration={verse.transliteration}
    dhatu_breakdown={verse.dhatu_breakdown}
    meaning={verse.meaning}
    story={verse.story}
    reflection={verse.reflection}
    glossary={glossary}
    folkArtStyle={chapter.folk_art_style}
    illustration={illustrationPath}
    illustrationAlt={illustrationAlt}
  />

  <VerseNav
    chapterSlug={slug!}
    currentVerse={verse.verse}
    totalVerses={chapter.verse_count}
    position="bottom"
    nextChapter={nextChapter}
  />
</BaseLayout>
