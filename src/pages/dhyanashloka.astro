---
import BaseLayout from '../layouts/BaseLayout.astro';
import FolkArtBorder from '../components/FolkArtBorder.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import yaml from 'js-yaml';

const content = yaml.load(
  readFileSync(join(process.cwd(), 'content', 'dhyanashloka.yaml'), 'utf-8')
) as {
  title: string;
  sanskrit_title: string;
  description: string;
  verses: Array<{
    number: number;
    sanskrit: string;
    transliteration: string;
    meaning: string;
  }>;
};

const hasIllustration = true;
---

<BaseLayout title="Dhyanashloka — Gita Kids" description="Meditation verses by Madhusudhan Saraswati, recited before studying the Bhagavad Gita.">
  <div class="max-w-reading mx-auto px-4 py-12">
    <!-- Header -->
    <header class="text-center mb-16">
      <span class="font-ui text-xs font-semibold uppercase tracking-widest text-gold">Before You Begin</span>
      <p lang="sa" class="font-devanagari text-4xl md:text-5xl text-saffron mt-4 mb-3">
        {content.sanskrit_title}
      </p>
      <h1 class="font-body text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        Dhyanashloka
      </h1>
      <p class="font-body text-base text-gray-600 max-w-md mx-auto leading-relaxed">
        Nine meditation verses traditionally recited before studying the Bhagavad Gita.
        They quiet the mind and turn it toward the divine.
      </p>
    </header>

    <!-- Illustration (if exists) -->
    {hasIllustration && (
      <div class="mb-16 rounded-xl overflow-hidden shadow-lg">
        <img
          src="/illustrations/dhyanashloka/001.png"
          alt="Dhyanashloka — meditation before studying the Gita"
          class="w-full"
          loading="eager"
        />
      </div>
    )}

    <!-- Introduction -->
    <FolkArtBorder style="madhubani" class="mb-16 p-6 md:p-8">
      <div class="font-body text-gray-700 leading-relaxed space-y-4">
        <p>
          Before every reading of the Gita, it is traditional to recite these nine
          <strong class="text-saffron">dhyanashlokas</strong> — verses of meditation.
          They were composed by the great scholar <strong>Madhusudhan Saraswati</strong>,
          who lived about 500 years ago.
        </p>
        <p>
          These verses are like tuning an instrument before playing music. They help us
          set aside distractions, remember the teachers who passed this wisdom down to us,
          and open our hearts to receive the teachings of the Gita.
        </p>
      </div>
    </FolkArtBorder>

    <!-- Verses -->
    <div class="space-y-16">
      {content.verses.map((verse, index) => (
        <article class="scroll-reveal" style={`transition-delay: ${index * 0.05}s`}>
          <!-- Verse number -->
          <div class="flex items-center gap-3 mb-6">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-saffron/10 font-ui text-sm font-bold text-saffron">
              {verse.number}
            </span>
            <div class="flex-1 h-px bg-gradient-to-r from-gold/30 to-transparent"></div>
          </div>

          <!-- Sanskrit -->
          <div class="text-center space-y-4 py-4">
            <p
              lang="sa" class="font-devanagari text-2xl md:text-3xl leading-loose text-gray-900 tracking-wider whitespace-pre-line"
              style="text-shadow: 0 1px 2px rgba(196, 162, 78, 0.15);"
              set:html={verse.sanskrit.trim()}
            />
            <p class="font-body text-sm md:text-base italic text-gray-600 tracking-wide leading-relaxed whitespace-pre-line">
              {verse.transliteration.trim()}
            </p>
          </div>

          <!-- Meaning -->
          <div class="mt-6 bg-white/60 rounded-lg border border-gold/15 px-6 py-5">
            <p class="font-body text-base text-gray-700 leading-relaxed">
              {verse.meaning.trim()}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Closing -->
    <div class="mt-20 text-center">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
        <span lang="sa" class="font-devanagari text-gold/50 text-lg">॥ इति ध्यानश्लोकाः ॥</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      </div>
      <p class="font-body text-gray-600 mb-6">
        Now, with a quiet mind, begin the Gita.
      </p>
      <a
        href="/chapters/01-arjuna-vishada-yoga"
        class="inline-flex items-center gap-2 px-6 py-3 bg-saffron text-white font-ui text-sm font-semibold rounded-lg hover:bg-saffron/90 transition-colors"
      >
        Begin Chapter 1 &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
