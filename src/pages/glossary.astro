---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getGlossary } from '../lib/content';

const glossary = getGlossary();

// Group by first letter
const grouped = glossary.reduce<Record<string, typeof glossary>>((acc, entry) => {
  const letter = entry.term[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(entry);
  return acc;
}, {});

const letters = Object.keys(grouped).sort();
---

<BaseLayout title="Glossary — Gita Kids">
  <div class="max-w-reading mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <span class="font-ui text-xs font-semibold uppercase tracking-widest text-gold">Reference</span>
      <h1 class="font-body text-3xl font-bold text-gray-900 mt-3">Glossary</h1>
      <p class="font-body text-base text-gray-600 mt-3">
        Sanskrit and Hindi terms you'll meet in the Gita, explained simply.
      </p>
    </header>

    <!-- Letter nav -->
    <nav class="flex flex-wrap justify-center gap-2 mb-10">
      {letters.map((letter) => (
        <a
          href={`#${letter}`}
          class="w-8 h-8 flex items-center justify-center rounded-full font-ui text-sm font-medium text-saffron hover:bg-saffron hover:text-white transition-colors border border-saffron/20"
        >
          {letter}
        </a>
      ))}
    </nav>

    <!-- Terms -->
    <div class="space-y-10">
      {letters.map((letter) => (
        <section id={letter}>
          <h2 class="font-ui text-lg font-bold text-saffron border-b border-gold/20 pb-2 mb-4">
            {letter}
          </h2>
          <dl class="space-y-4">
            {grouped[letter].map((entry) => (
              <div class="py-2">
                <dt class="font-body text-lg font-semibold text-gray-900 capitalize">
                  {entry.term}
                  {entry.sanskrit && (
                    <span lang="sa" class="font-devanagari text-base font-normal text-saffron/70 ml-2">{entry.sanskrit}</span>
                  )}
                </dt>
                <dd class="font-body text-base text-gray-600 leading-relaxed mt-1">
                  {entry.definition}
                </dd>
              </div>
            ))}
          </dl>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
