---
import BaseLayout from '../layouts/BaseLayout.astro';
import FolkArtBorder from '../components/FolkArtBorder.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import yaml from 'js-yaml';

const content = yaml.load(
  readFileSync(join(process.cwd(), 'content', 'gitamahatmyam.yaml'), 'utf-8')
) as {
  title: string;
  sanskrit_title: string;
  description: string;
  introduction: string;
  chapters: Array<{
    number: number;
    title: string;
    sanskrit_chapter: string;
    chapter_name: string;
    story: string;
  }>;
  closing_sanskrit: string;
  closing_meaning: string;
};

// Folk art styles per chapter (matches meta.yaml assignments)
const chapterStyles: Record<number, string> = {
  1: 'madhubani',
  2: 'pichwai',
  3: 'pattachitra',
  4: 'madhubani',
  5: 'warli',
  6: 'kalamkari',
  7: 'madhubani',
  8: 'pichwai',
  9: 'pattachitra',
  10: 'warli',
  11: 'kalamkari',
  12: 'pichwai',
  13: 'madhubani',
  14: 'pattachitra',
  15: 'kalamkari',
  16: 'warli',
  17: 'pichwai',
  18: 'madhubani',
};
---

<BaseLayout title="Gitamahatmyam — Gita Kids" description="The Glory of the Gita — eighteen tales from the Padma Purana, one for each chapter, showing how a single teaching can transform a life.">
  <div class="max-w-reading mx-auto px-4 py-12">
    <!-- Header -->
    <header class="text-center mb-16">
      <span class="font-ui text-xs font-semibold uppercase tracking-widest text-gold">After You Finish</span>
      <p lang="sa" class="font-devanagari text-4xl md:text-5xl text-saffron mt-4 mb-3">
        {content.sanskrit_title}
      </p>
      <h1 class="font-body text-2xl md:text-3xl font-bold text-gray-900 mb-4">
        The Glory of the Gita
      </h1>
      <p class="font-body text-base text-gray-600 max-w-md mx-auto leading-relaxed">
        Eighteen tales from the Varaha Purana — one for each chapter — showing
        how a single teaching can change a life forever.
      </p>
    </header>

    <!-- Introduction -->
    <FolkArtBorder style="madhubani" class="mb-16 p-6 md:p-8">
      <div class="font-body text-gray-700 leading-relaxed space-y-4">
        {content.introduction.trim().split('\n\n').map((para) => (
          <p set:html={para.trim()} />
        ))}
      </div>
    </FolkArtBorder>

    <!-- Chapter Stories -->
    <div class="space-y-16">
      {content.chapters.map((ch, index) => (
        <article class="scroll-reveal" style={`transition-delay: ${index * 0.03}s`}>
          <!-- Chapter number and title -->
          <div class="flex items-center gap-3 mb-6">
            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-saffron/10 font-ui text-sm font-bold text-saffron">
              {ch.number}
            </span>
            <div class="flex-1">
              <h2 class="font-body text-lg font-bold text-gray-900 leading-snug">
                {ch.title}
              </h2>
              <p lang="sa" class="font-devanagari text-sm text-gold/70 mt-0.5">
                {ch.sanskrit_chapter} — {ch.chapter_name}
              </p>
            </div>
          </div>

          <!-- Story -->
          <FolkArtBorder style={chapterStyles[ch.number] || 'madhubani'} class="p-5 md:p-7">
            <div class="font-body text-base text-gray-700 leading-relaxed space-y-4">
              {ch.story.trim().split('\n\n').map((para) => (
                <p>{para.trim()}</p>
              ))}
            </div>
          </FolkArtBorder>
        </article>
      ))}
    </div>

    <!-- Closing -->
    <div class="mt-20 text-center">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
        <span lang="sa" class="font-devanagari text-gold/50 text-lg">{content.closing_sanskrit}</span>
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      </div>
      <p class="font-body text-sm text-gray-500 italic mb-8">
        {content.closing_meaning}
      </p>
      <p class="font-body text-gray-600 mb-6">
        The Gita is not a book you finish. It is a book that finishes you —
        and then begins you again.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-saffron text-white font-ui text-sm font-semibold rounded-lg hover:bg-saffron/90 transition-colors"
      >
        &larr; Back to Home
      </a>
    </div>
  </div>
</BaseLayout>
